# AutoBot Inbox — Environment Variables
# Copy this to .env and fill in your values.

# Anthropic API key (required — get from console.anthropic.com)
ANTHROPIC_API_KEY=

# OpenRouter API key (optional — enables non-Anthropic models via openrouter.ai)
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Gmail OAuth (run `npm run setup-gmail` to get these)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=

# Database: set DATABASE_URL for real Postgres (production/Supabase).
# Omit for PGlite in-process mode (demo/dev).
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Budget ceiling per day (USD)
DAILY_BUDGET_USD=20

# Autonomy level: 0 = all drafts need approval, 1 = auto-archive noise, 2 = handle all but G2
AUTONOMY_LEVEL=0

# Poll interval in seconds (default 60)
GMAIL_POLL_INTERVAL=60

# Credential encryption for multi-account support
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# Outlook / Microsoft Graph (run `node scripts/setup-outlook.js` to get refresh token)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_TENANT_ID=

# Slack (Bolt App — create at api.slack.com/apps)
# Socket Mode for MVP/dev. Production uses Events API.
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# Slack channel ID for daily digest push (e.g., C0123456789)
SLACK_DIGEST_CHANNEL=

# Telegram Bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram user IDs for board members
# Find your ID: message @userinfobot on Telegram
TELEGRAM_BOARD_USER_IDS=

# Webhook HMAC secrets (per-source, used for signature verification)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET_GITHUB=
WEBHOOK_SECRET_LINEAR=
WEBHOOK_SECRET_STRIPE=
WEBHOOK_SECRET_GENERIC=

# HMAC signing key for agent identity claims (ADR-015). Generate with: openssl rand -hex 32
AGENT_SIGNING_KEY=

# Process role: run a subset of the system in a single process.
# Values: ingestion | agents | api | full (default)
# Deploy as one process now; split into 3 Railway services when volume demands it.
PROCESS_ROLE=full

# Default GitHub repo for executor-ticket issue creation (ADR-002: individual install)
DEFAULT_REPO_OWNER=staqsIO
DEFAULT_REPO_NAME=optimus

# Neo4j Knowledge Graph (optional — learning features disabled when unset)
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=

# Resend email (required for staqs.io demo notifications — redesign + blueprint)
RESEND_API_KEY=
RESEND_FROM=STAQS.IO <hello@staqs.io>

# Ports (defaults: API=3001, Dashboard=3100)
API_PORT=3001
DASHBOARD_PORT=3100
