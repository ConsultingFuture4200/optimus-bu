# Optimus — Docker Compose environment variables
# Copy this to .env and fill in required values.
#
# For dev (docker compose up):   only ANTHROPIC_API_KEY is required to start
# For prod (docker compose -f compose.prod.yml up): all (prod required) values must be set

# ── AI Provider ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Gmail Integration ──────────────────────────────────────────────────────────
# Run `cd autobot-inbox && npm run setup-gmail` to generate these
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER_EMAIL=

# ── Agent Runtime ──────────────────────────────────────────────────────────────
DAILY_BUDGET_USD=20
AUTONOMY_LEVEL=0
GMAIL_POLL_INTERVAL=60
PROCESS_ROLE=full
DEFAULT_REPO_OWNER=staqsIO
DEFAULT_REPO_NAME=optimus

# ── Board Workstation Auth (GitHub OAuth) ──────────────────────────────────────
# Create OAuth app at: github.com/settings/applications/new
# Dev callback URL:  http://localhost:3200/api/auth/callback/github
# Prod callback URL: https://your-domain.com/api/auth/callback/github
GITHUB_ID=
GITHUB_SECRET=

# NextAuth secret — generate: openssl rand -base64 32  (prod required)
NEXTAUTH_SECRET=

# AES-256-GCM key for encrypting stored API keys — generate: openssl rand -hex 32  (prod required)
API_KEY_ENCRYPTION_SECRET=

# Comma-separated GitHub usernames always allowed to sign in as board members
BOARD_MEMBERS=ecgang,ConsultingFuture4200

# ── API Auth ───────────────────────────────────────────────────────────────────
# HMAC secret for dashboard → autobot-inbox API calls  (prod required)
API_SECRET=

# ── Supabase (autobot-inbox/dashboard — optional, can use local Postgres via API) ─
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Optional Channels ──────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# ── Production Only ────────────────────────────────────────────────────────────
# Uncomment and set when deploying to production:
# POSTGRES_PASSWORD=changeme-use-a-strong-password
# REDIS_PASSWORD=changeme-use-a-strong-password
# INBOX_DASHBOARD_URL=https://inbox.yourdomain.com
# BOARD_URL=https://board.yourdomain.com
